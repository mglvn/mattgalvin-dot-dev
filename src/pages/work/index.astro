---
import Layout from "../../layouts/Layout.astro";
import { parseTags } from "../../lib/db";
import { getCachedPostsList } from "../../lib/posts-cache";

const { DB, POSTS_CACHE } = Astro.locals.runtime.env;
const projects = await getCachedPostsList(POSTS_CACHE, DB, "projects");
---

<Layout title="Work" description="Selected projects by Matt Galvin.">
  <div style="padding-top: 10rem; padding-bottom: 4rem; padding-left: var(--px); padding-right: var(--px); max-width: 1200px; margin: 0 auto;">

    <div class="anim-1" style="margin-bottom: 5rem;">
<h1 class="font-display" style="font-size: clamp(3rem, 9vw, 9rem); font-weight: 300; line-height: 0.9; letter-spacing: -0.02em;">
        Selected<br />
        <em style="font-style: italic; color: var(--color-rust);">projects.</em>
      </h1>
    </div>

    {projects.length === 0 ? (
      <p style="font-size: 0.875rem; color: var(--color-smoke); font-weight: 300;">No projects yet.</p>
    ) : (
      <div class="anim-2 card-grid">
        {projects.map((p) => (
          <a href={`/work/${p.slug}`} class="card" style={p.hero_image ? `background-image: url('${p.hero_image}')` : ""}>
            <div class="card-body">
              <div></div>
              <div class="card-bottom">
                {p.description && <p class="card-desc">{p.description}</p>}
                <div class="card-title-row">
                  <h2 class="card-title font-display">{p.title}</h2>
                  <svg class="card-arrow" width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                {parseTags(p.tags).length > 0 && (
                  <div class="card-tags">
                    {parseTags(p.tags).map((t) => (
                      <span class="card-tag">{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .card-grid { grid-template-columns: 1fr; }
  }

  .card {
    background: #332b1e;
    background-size: cover;
    background-position: center;
    border: 1px solid #5a4e3c;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    position: relative;
    transition: border-color 0.2s, transform 0.3s;
  }
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.7) 100%);
    border-radius: inherit;
    transition: background 0.3s;
  }
  .card:hover::after {
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.85) 100%);
  }
  .card:hover {
    border-color: var(--color-rust);
    transform: translateY(-2px);
  }

  .card-body {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
  }

  .card-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-arrow {
    color: var(--color-rust);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s, transform 0.25s;
  }
  .card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-desc {
    font-size: 0.8rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.75);
    font-weight: 300;
    margin: 0;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .card:hover .card-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
    color: #fff;
    transition: color 0.2s;
  }

  .card:hover .card-title {
    color: var(--color-rust);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-tag {
    font-family: 'Source Code Pro', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.5);
  }
</style>
