---
import Layout from "../layouts/Layout.astro";
import { formatDate, parseTags } from "../lib/db";
import { getCachedPostsList } from "../lib/posts-cache";

const { DB, POSTS_CACHE } = Astro.locals.runtime.env;
const [recentPosts, featuredProjects] = await Promise.all([
  getCachedPostsList(POSTS_CACHE, DB, "blog").then((p) => p.slice(0, 3)).catch(() => []),
  getCachedPostsList(POSTS_CACHE, DB, "projects").then((p) => p.filter((p) => p.featured === 1).slice(0, 3)).catch(() => []),
]);

---

<Layout title="Home">
  <!-- HERO -->
  <section style="min-height: 100svh; display: flex; flex-direction: column; padding: 0 var(--px);">
    <!-- Spacer for nav -->
    <div style="height: 6rem;"></div>

    <!-- Main hero content -->
    <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; max-width: 1200px; width: 100%; margin: 0 auto; gap: 2rem;">

      <!-- Name -->
      <div class="anim-1">
        <h1 class="font-display" style="font-size: clamp(5.5rem, 14vw, 15rem); font-weight: 300; line-height: 0.88; letter-spacing: -0.02em; color: var(--color-ink);">
          Matt<br />
          <em style="font-style: italic; color: var(--color-rust);">Galvin</em>
        </h1>
      </div>

      <!-- Sub row -->
      <div class="anim-2" style="display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem;">
        <p style="font-size: 1.15rem; font-weight: 300; line-height: 1.6; color: var(--color-smoke); max-width: 44ch;">
          I lead a team of product experts by day — and build things obsessively by night.
        </p>
        <a href="#work" class="link-arrow">
          View my work
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="padding-bottom: 2.5rem; width: 100%; display: flex; justify-content: center;">
      <div class="scroll-arrow">↓</div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" style="padding: 3rem var(--px); max-width: 1200px; margin: 0 auto;">

    {featuredProjects.length === 0 ? (
      <p style="font-size: 0.875rem; color: var(--color-smoke); font-weight: 300;">No featured projects yet.</p>
    ) : (
      <div class="featured-grid">
        {featuredProjects.map((p) => (
          <a href={`/work/${p.slug}`} class="featured-card" style={p.hero_image ? `background-image: url('${p.hero_image}')` : ""}>
            <div class="featured-card-inner">
              <div></div>
              <div class="featured-bottom">
                {p.description && <p class="featured-desc">{p.description}</p>}
                <div class="featured-title-row">
                  <h3 class="featured-title font-display">{p.title}</h3>
                  <svg class="featured-arrow" width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                {parseTags(p.tags).length > 0 && (
                  <div class="card-tags">
                    {parseTags(p.tags).map((t) => <span class="card-tag">{t}</span>)}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;">
        <a href="/work" class="link-arrow">
          All projects
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    )}
  </section>

  <!-- WRITING -->
  <section id="blog" style="padding: 3rem var(--px) 7rem; max-width: 1200px; margin: 0 auto;">

    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3rem;">
      <h2 class="font-display" style="font-size: clamp(2rem, 5vw, 4rem); font-weight: 400; line-height: 1; letter-spacing: -0.01em;">Blog</h2>
      <a href="/blog" class="link-arrow">
        All posts
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div style="border-top: 1px solid var(--color-rule);">
      {recentPosts.length === 0 ? (
        <p style="padding: 2rem 1rem; font-size: 0.875rem; color: var(--color-smoke); font-weight: 300;">No posts yet.</p>
      ) : recentPosts.map((p) => (
        <a href={`/blog/${p.slug}`} class="blog-row" style="padding: 1.75rem 1rem; border-bottom: 1px solid var(--color-rule); text-decoration: none; color: inherit; display: block;">
          <div class="blog-row-inner">
            <span style="font-family: 'Source Code Pro', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: var(--color-smoke); padding-top: 0.2rem;">{formatDate(p.date)}</span>
            <div>
              <h3 class="font-display" style="font-size: 1.4rem; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 0.3rem; transition: color 0.2s;">
                {p.title}
              </h3>
              {p.description && (
                <p style="font-size: 0.875rem; color: var(--color-smoke); font-weight: 300;">{p.description}</p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- DIVIDER CTA -->
  <section style="padding: 7rem var(--px); max-width: 1200px; margin: 0 auto; text-align: center;">
    <p class="font-display" style="font-size: clamp(2rem, 6vw, 5rem); font-weight: 300; line-height: 1.15; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: 2rem;">
      Let's build something<br />
      <em style="color: var(--color-rust); font-style: italic;">together.</em>
    </p>
    <a href="mailto:hello@mattgalvin.dev" class="link-arrow" style="font-size: 0.8rem;">
      Get in touch
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>
</Layout>

<style>
  .scroll-arrow {
    font-size: 1.5rem;
    color: var(--color-smoke);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .featured-grid { grid-template-columns: 1fr; }
  }

  .featured-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid #5a4e3c;
    background: #332b1e;
    background-size: cover;
    background-position: center;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 3 / 2;
    transition: border-color 0.2s, transform 0.3s;
  }
  .featured-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.7) 100%);
    border-radius: inherit;
    transition: background 0.3s;
  }
  .featured-card:hover::after {
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.85) 100%);
  }
  .featured-card:hover {
    border-color: var(--color-rust);
    transform: translateY(-2px);
  }

  .featured-card-inner {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    box-sizing: border-box;
  }

  .featured-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .featured-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .featured-title {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    color: #fff;
    transition: color 0.2s;
  }
  .featured-card:hover .featured-title {
    color: var(--color-rust);
  }

  .featured-desc {
    font-size: 0.8rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.75);
    font-weight: 300;
    margin: 0;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .featured-card:hover .featured-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-arrow {
    color: var(--color-rust);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s, transform 0.25s;
  }
  .featured-card:hover .featured-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-tag {
    font-family: 'Source Code Pro', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.5);
  }
</style>
