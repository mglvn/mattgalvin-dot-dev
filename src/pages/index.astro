---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import { listPosts, formatDate, parseTags } from "../lib/db";
import { getPlatformProxy } from "wrangler";

const { env, dispose } = await getPlatformProxy<{ DB: D1Database }>();
const recentPosts = await listPosts(env.DB, "blog", true).then((p) => p.slice(0, 3)).catch(() => []);
const projects = await listPosts(env.DB, "projects", true).then((p) => p.slice(0, 3)).catch(() => []);
await dispose();

---

<Layout title="Home">
  <!-- HERO -->
  <section style="min-height: 100svh; display: flex; flex-direction: column; padding: 0 2.5rem;">
    <!-- Spacer for nav -->
    <div style="height: 6rem;"></div>

    <!-- Main hero content -->
    <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; max-width: 1200px; width: 100%; margin: 0 auto; gap: 2rem;">

      <!-- Name -->
      <div class="anim-1">
        <h1 class="font-display" style="font-size: clamp(5.5rem, 14vw, 15rem); font-weight: 300; line-height: 0.88; letter-spacing: -0.02em; color: #1a1612;">
          Matt<br />
          <em style="font-style: italic; color: #b5421a;">Galvin</em>
        </h1>
      </div>

      <!-- Sub row -->
      <div class="anim-2" style="display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem;">
        <p style="font-size: 1.15rem; font-weight: 300; line-height: 1.6; color: #3d3830; max-width: 44ch;">
          I lead a team of product experts by day — and build things obsessively by night.
        </p>
        <a href="#work" class="link-arrow">
          View my work
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="padding-bottom: 2.5rem; width: 100%; display: flex; justify-content: center;">
      <div class="scroll-arrow">↓</div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" style="padding: 7rem 2.5rem; max-width: 1200px; margin: 0 auto;">

    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3rem;">
      <h2 class="font-display" style="font-size: clamp(2rem, 5vw, 4rem); font-weight: 400; line-height: 1; letter-spacing: -0.01em;">Projects</h2>
      <a href="/work" class="link-arrow">
        All projects
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    {projects.length === 0 ? (
      <p style="font-size: 0.875rem; color: #8a8076; font-weight: 300;">No projects yet.</p>
    ) : (
      <div class="card-grid">
        {projects.map((p, i) => (
          <a href={`/work/${p.slug}`} class="work-card">
            {p.hero_image && (
              <div class="card-img-wrap">
                <img src={p.hero_image} alt={p.title} class="card-img" loading="lazy" />
              </div>
            )}
            <div class="card-body">
              <div class="card-meta">
                <span class="card-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="card-year">{p.date.slice(0, 4)} ↗</span>
              </div>
              <h3 class="card-title font-display">{p.title}</h3>
              {p.description && <p class="card-desc">{p.description}</p>}
              {parseTags(p.tags).length > 0 && (
                <div class="card-tags">
                  {parseTags(p.tags).map((t) => <span class="card-tag">{t}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- WRITING -->
  <section id="blog" style="padding: 7rem 2.5rem; max-width: 1200px; margin: 0 auto;">

    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3rem;">
      <h2 class="font-display" style="font-size: clamp(2rem, 5vw, 4rem); font-weight: 400; line-height: 1; letter-spacing: -0.01em;">Blog</h2>
      <a href="/blog" class="link-arrow">
        All posts
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div style="border-top: 1px solid #ccc5b8;">
      {recentPosts.length === 0 ? (
        <p style="padding: 2rem 1rem; font-size: 0.875rem; color: #8a8076; font-weight: 300;">No posts yet.</p>
      ) : recentPosts.map((p) => (
        <a href={`/blog/${p.slug}`} class="blog-row" style="display: grid; grid-template-columns: 7rem 1fr; gap: 2rem; align-items: baseline; padding: 1.75rem 1rem; border-bottom: 1px solid #ccc5b8; text-decoration: none; color: inherit;">
          <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: #8a8076; padding-top: 0.2rem;">{formatDate(p.date)}</span>
          <div>
            <h3 class="font-display" style="font-size: 1.4rem; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 0.3rem; transition: color 0.2s;">
              {p.title}
            </h3>
            {p.description && (
              <p style="font-size: 0.875rem; color: #8a8076; font-weight: 300;">{p.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- DIVIDER CTA -->
  <section style="padding: 7rem 2.5rem; max-width: 1200px; margin: 0 auto; text-align: center;">
    <p class="font-display" style="font-size: clamp(2rem, 6vw, 5rem); font-weight: 300; line-height: 1.15; letter-spacing: -0.02em; color: #1a1612; margin-bottom: 2rem;">
      Let's build something<br />
      <em style="color: #b5421a; font-style: italic;">together.</em>
    </p>
    <a href="mailto:hello@mattgalvin.dev" class="link-arrow" style="font-size: 0.8rem;">
      Get in touch
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>
</Layout>

<style>
  .scroll-arrow {
    font-size: 1.5rem;
    color: #8a8076;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: #ccc5b8;
  }
  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }

  .work-card {
    background: #f2ede3;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .card-img-wrap {
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .work-card:hover .card-img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: #ccc5b8;
  }

  .card-year {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: #b5421a;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
    transition: color 0.2s;
  }

  .work-card:hover .card-title {
    color: #b5421a;
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #6a6460;
    font-weight: 300;
    margin: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid #ccc5b8;
    color: #8a8076;
  }
</style>
