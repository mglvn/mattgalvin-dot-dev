---
import Layout from "../../layouts/Layout.astro";
import { listPosts, formatDate } from "../../lib/db";

const db = Astro.locals.runtime.env.DB;
const posts = await listPosts(db, "blog", true);
---

<Layout title="Blog" description="Writing by Matt Galvin on design, engineering, and the craft of building.">
  <div style="padding-top: 10rem; padding-bottom: 4rem; padding-left: 2.5rem; padding-right: 2.5rem; max-width: 1200px; margin: 0 auto;">

    <div class="anim-1" style="margin-bottom: 5rem;">
      <p style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8076; margin-bottom: 1rem;">Writing</p>
      <h1 class="font-display" style="font-size: clamp(3rem, 9vw, 9rem); font-weight: 300; line-height: 0.9; letter-spacing: -0.02em;">
        Thoughts on<br />
        <em style="font-style: italic; color: #b5421a;">building things.</em>
      </h1>
    </div>

    <div class="anim-2" style="border-top: 1px solid #ccc5b8;">
      {posts.length === 0 ? (
        <p style="padding: 3rem 1rem; font-size: 0.875rem; color: #8a8076; font-weight: 300;">No posts yet.</p>
      ) : posts.map((p) => (
        <a href={`/blog/${p.slug}`} class="blog-row" style="display: grid; grid-template-columns: 7rem 1fr; gap: 2rem; align-items: baseline; padding: 2rem 1rem; border-bottom: 1px solid #ccc5b8; text-decoration: none; color: inherit;">
          <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: #8a8076;">{formatDate(p.date)}</span>
          <div>
            <h2 class="font-display" style="font-size: 1.5rem; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 0.4rem;">{p.title}</h2>
            {p.description && (
              <p style="font-size: 0.875rem; color: #8a8076; font-weight: 300; line-height: 1.6;">{p.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
