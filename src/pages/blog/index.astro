---
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../lib/db";
import { getCachedPostsList } from "../../lib/posts-cache";

const { DB, POSTS_CACHE } = Astro.locals.runtime.env;
const posts = await getCachedPostsList(POSTS_CACHE, DB, "blog");
---

<Layout title="Blog" description="Writing by Matt Galvin on design, engineering, and the craft of building.">
  <div style="padding-top: 10rem; padding-bottom: 4rem; padding-left: var(--px); padding-right: var(--px); max-width: 1200px; margin: 0 auto;">

    <div class="anim-1" style="margin-bottom: 5rem;">
      <h1 class="font-display" style="font-size: clamp(3rem, 9vw, 9rem); font-weight: 300; line-height: 0.9; letter-spacing: -0.02em;">
        Thoughts on<br />
        <em style="font-style: italic; color: var(--color-rust);">building things.</em>
      </h1>
    </div>

    <div class="anim-2" style="border-top: 1px solid var(--color-rule);">
      {posts.length === 0 ? (
        <p style="padding: 3rem 1rem; font-size: 0.875rem; color: var(--color-smoke); font-weight: 300;">No posts yet.</p>
      ) : posts.map((p) => (
        <a href={`/blog/${p.slug}`} class="blog-row" style="display: block; padding: 2rem 1rem; border-bottom: 1px solid var(--color-rule); text-decoration: none; color: inherit;">
          <div class="blog-row-inner">
            <span style="font-family: 'Source Code Pro', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: var(--color-smoke);">{formatDate(p.date)}</span>
            <div>
              <h2 class="font-display" style="font-size: 1.5rem; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 0.4rem;">{p.title}</h2>
              {p.description && (
                <p style="font-size: 0.875rem; color: var(--color-smoke); font-weight: 300; line-height: 1.6;">{p.description}</p>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
