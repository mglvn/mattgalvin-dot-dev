---
import Layout from "../../layouts/Layout.astro";

const posts = [
  {
    date: "Apr 2026",
    slug: "#",
    title: "The Art of Saying No to Features",
    excerpt: "How constraint breeds creativity in software design. When every idea becomes a feature, nothing feels like a choice.",
    readTime: "5 min",
  },
  {
    date: "Mar 2026",
    slug: "#",
    title: "Building With the Grain",
    excerpt: "Why fighting your tools is usually the wrong move. The best software feels like it was always there.",
    readTime: "4 min",
  },
  {
    date: "Feb 2026",
    slug: "#",
    title: "On Shipping Imperfect Things",
    excerpt: "Done is better than perfect, but not as simple as it sounds. Some thoughts on the courage it takes to ship.",
    readTime: "6 min",
  },
  {
    date: "Jan 2026",
    slug: "#",
    title: "The Case for Boring Technology",
    excerpt: "Choosing proven tools over exciting ones isn't a lack of ambition — it's a form of respect for the problem.",
    readTime: "7 min",
  },
  {
    date: "Dec 2025",
    slug: "#",
    title: "Writing Code for the Next Person",
    excerpt: "That next person is probably you, six months from now, at 2am with no context. Be kind to them.",
    readTime: "4 min",
  },
];
---

<Layout title="Blog" description="Writing by Matt Galvin on design, engineering, and the craft of building.">
  <div style="padding-top: 10rem; padding-bottom: 4rem; padding-left: 2.5rem; padding-right: 2.5rem; max-width: 1200px; margin: 0 auto;">

    <div class="anim-1" style="margin-bottom: 5rem;">
      <p style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8076; margin-bottom: 1rem;">Writing</p>
      <h1 class="font-display" style="font-size: clamp(3rem, 9vw, 9rem); font-weight: 300; line-height: 0.9; letter-spacing: -0.02em;">
        Thoughts on<br />
        <em style="font-style: italic; color: #b5421a;">craft.</em>
      </h1>
    </div>

    <div class="anim-2" style="border-top: 1px solid #ccc5b8;">
      {posts.map((p) => (
        <a href={p.slug} class="blog-row" style="display: grid; grid-template-columns: 7rem 1fr auto; gap: 2rem; align-items: baseline; padding: 2rem 1rem; border-bottom: 1px solid #ccc5b8; text-decoration: none; color: inherit;">
          <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: #8a8076;">{p.date}</span>
          <div>
            <h2 class="font-display" style="font-size: 1.5rem; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 0.4rem;">{p.title}</h2>
            <p style="font-size: 0.875rem; color: #8a8076; font-weight: 300; line-height: 1.6;">{p.excerpt}</p>
          </div>
          <span style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; color: #ccc5b8; white-space: nowrap; align-self: center;">{p.readTime}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
