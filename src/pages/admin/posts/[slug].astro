---
import { getPost, parseTags } from "../../../lib/db";
import MarkdownEditor from "../../../components/MarkdownEditor.astro";

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const post = await getPost(db, slug!);

if (!post) {
  return Astro.redirect("/admin");
}

const tags = parseTags(post.tags).join(", ");
const viewHref = post.type === "projects" ? `/work/${post.slug}` : `/blog/${post.slug}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.title} — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background: #f2ede3; margin: 0; min-height: 100svh; font-family: 'DM Sans', system-ui, sans-serif;">

    <!-- Top bar -->
    <header style="position: sticky; top: 0; z-index: 10; background: #f2ede3; border-bottom: 1px solid #ccc5b8; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
      <div style="display: flex; align-items: center; gap: 2rem;">
        <a href="/admin" style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8076; text-decoration: none;">
          ← Posts
        </a>
        <span style="color: #ccc5b8;">|</span>
        <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1612; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
          {post.title}
        </span>
      </div>
      <div style="display: flex; align-items: center; gap: 1.5rem;">
        {post.published && (
          <a
            href={viewHref}
            target="_blank"
            style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076; text-decoration: none;"
          >
            View live ↗
          </a>
        )}
        <form method="POST" action="/api/auth/logout">
          <button type="submit" style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076; background: none; border: none; cursor: pointer; padding: 0;">
            Sign out
          </button>
        </form>
      </div>
    </header>

    <main style="max-width: 1000px; margin: 0 auto; padding: 3rem 2rem 6rem;">
      <form id="post-form" style="display: flex; flex-direction: column; gap: 2rem;">

        <!-- Title + slug -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
          <div>
            <label class="field-label">Title</label>
            <input id="title" name="title" type="text" required class="field-input" value={post.title} />
          </div>
          <div>
            <label class="field-label">Slug</label>
            <input type="text" class="field-input field-input--mono field-input--disabled" value={post.slug} disabled />
          </div>
        </div>

        <!-- Description -->
        <div>
          <label class="field-label">Description</label>
          <textarea id="description" name="description" rows="2" class="field-input" style="resize: vertical;">{post.description}</textarea>
        </div>

        <!-- Body -->
        <div>
          <label class="field-label">Body</label>
          <MarkdownEditor value={post.body} />
        </div>

        <!-- Hero image -->
        <div>
          <label class="field-label">Hero Image</label>
          <div style="display: flex; gap: 0.75rem; align-items: stretch;">
            <input id="hero_image" name="hero_image" type="text" class="field-input" value={post.hero_image} placeholder="URL or upload →" style="flex: 1;" />
            <label class="btn-upload" title="Upload image">
              Upload
              <input type="file" id="hero-upload-input" accept="image/*" style="display:none;" />
            </label>
          </div>
          <div id="hero-preview-wrap" style={`margin-top: 0.75rem; display: ${post.hero_image ? 'block' : 'none'};`}>
            <img id="hero-preview" src={post.hero_image || undefined} alt="" style="max-height: 160px; max-width: 100%; object-fit: cover; border: 1px solid #ccc5b8;" />
          </div>
        </div>

        <!-- Meta row -->
        <div style="background: #ede8de; border: 1px solid #ccc5b8; padding: 1.5rem; display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.5rem; align-items: end;">
          <div>
            <label class="field-label">Tags</label>
            <input id="tags" name="tags" type="text" class="field-input" value={tags} placeholder="Go, TypeScript" />
          </div>
          <div>
            <label class="field-label">Type</label>
            <select id="type" name="type" class="field-input">
              <option value="blog" selected={post.type === "blog"}>Blog</option>
              <option value="projects" selected={post.type === "projects"}>Projects</option>
            </select>
          </div>
          <div>
            <label class="field-label">Status</label>
            <select id="status-select" name="status" class="field-input">
              <option value="active" selected={post.status === "active"}>Active</option>
              <option value="wip" selected={post.status === "wip"}>WIP</option>
              <option value="archived" selected={post.status === "archived"}>Archived</option>
            </select>
          </div>
          <div>
            <label class="field-label">Date</label>
            <input id="date" name="date" type="date" required class="field-input" value={post.date} />
          </div>
        </div>

        <!-- Published + submit -->
        <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 0.75rem; border-top: 1px solid #ccc5b8;">
          <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076;">
            <input id="published" name="published" type="checkbox" checked={post.published === 1}
              style="width: 15px; height: 15px; accent-color: #1a1612;" />
            Published
          </label>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <span id="save-status" style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.06em; color: #6a8a6a; opacity: 0; transition: opacity 0.3s;"></span>
            <button id="save-btn" type="submit" class="btn-save">Save changes</button>
          </div>
        </div>

      </form>
    </main>

    <style>
      .field-label {
        display: block;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6a6460;
        margin-bottom: 0.5rem;
      }
      .field-input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.75rem 1rem;
        background: transparent;
        border: 1px solid #ccc5b8;
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 1rem;
        font-weight: 300;
        color: #1a1612;
        outline: none;
        appearance: none;
      }
      .field-input:focus { border-color: #8a8076; }
      .field-input--mono { font-family: 'Space Mono', monospace; font-size: 0.85rem; }
      .field-input--disabled { opacity: 0.45; cursor: not-allowed; }
      .btn-save {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #f2ede3;
        background: #1a1612;
        border: none;
        cursor: pointer;
        padding: 0.75rem 1.75rem;
        transition: background 0.2s;
      }
      .btn-save:disabled { opacity: 0.6; cursor: not-allowed; }
      .btn-save.is-success { background: #4a7a4a; }
      .btn-save.is-error { background: #b5421a; }
      .btn-upload {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #8a8076;
        background: #ede8de;
        border: 1px solid #ccc5b8;
        cursor: pointer;
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        white-space: nowrap;
        transition: color 0.15s;
      }
      .btn-upload:hover { color: #1a1612; }
    </style>

    <script define:vars={{ slug: post.slug }}>
      // Hero image upload
      const heroInput = document.getElementById("hero_image");
      const heroUpload = document.getElementById("hero-upload-input");
      const heroPreviewWrap = document.getElementById("hero-preview-wrap");
      const heroPreview = document.getElementById("hero-preview");

      heroUpload.addEventListener("change", async () => {
        const file = heroUpload.files?.[0];
        if (!file) return;
        const label = heroUpload.closest("label");
        label.textContent = "Uploading…";
        try {
          const fd = new FormData();
          fd.append("file", file);
          const res = await fetch("/api/uploads", { method: "POST", body: fd });
          if (!res.ok) throw new Error();
          const { url } = await res.json();
          heroInput.value = url;
          heroPreview.src = url;
          heroPreviewWrap.style.display = "block";
        } catch {
          alert("Upload failed.");
        } finally {
          label.innerHTML = 'Upload<input type="file" id="hero-upload-input" accept="image/*" style="display:none;" />';
          label.querySelector("input").addEventListener("change", heroUpload.onchange);
        }
      });

      heroInput.addEventListener("input", () => {
        const url = heroInput.value.trim();
        if (url) {
          heroPreview.src = url;
          heroPreviewWrap.style.display = "block";
        } else {
          heroPreviewWrap.style.display = "none";
        }
      });

      const form = document.getElementById("post-form");
      const saveBtn = document.getElementById("save-btn");
      const saveStatus = document.getElementById("save-status");

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        saveBtn.textContent = "Saving…";
        saveBtn.disabled = true;
        saveBtn.classList.remove("is-success", "is-error");
        saveStatus.style.opacity = "0";

        const tagsRaw = document.getElementById("tags").value;
        const tags = tagsRaw.split(",").map((t) => t.trim()).filter(Boolean);

        const body = {
          title:       document.getElementById("title").value,
          description: document.getElementById("description").value,
          body:        document.getElementById("body").value,
          tags:        JSON.stringify(tags),
          type:        document.getElementById("type").value,
          status:      document.getElementById("status-select").value,
          published:   document.getElementById("published").checked,
          date:        document.getElementById("date").value,
          hero_image:  document.getElementById("hero_image").value,
        };

        const res = await fetch(`/api/posts/${slug}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          saveBtn.textContent = "Saved ✓";
          saveBtn.classList.add("is-success");
          setTimeout(() => {
            saveBtn.textContent = "Save changes";
            saveBtn.classList.remove("is-success");
            saveBtn.disabled = false;
          }, 2000);
        } else {
          const err = await res.json();
          saveBtn.textContent = "Failed";
          saveBtn.classList.add("is-error");
          saveStatus.textContent = err.error ?? "Something went wrong.";
          saveStatus.style.color = "#b5421a";
          saveStatus.style.opacity = "1";
          setTimeout(() => {
            saveBtn.textContent = "Save changes";
            saveBtn.classList.remove("is-error");
            saveBtn.disabled = false;
          }, 3000);
        }
      });
    </script>

  </body>
</html>
