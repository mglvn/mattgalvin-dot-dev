---
export const prerender = false;
import MarkdownEditor from "../../../components/MarkdownEditor.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Post — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background: #f2ede3; margin: 0; min-height: 100svh; font-family: 'DM Sans', system-ui, sans-serif;">

    <!-- Top bar -->
    <header style="position: sticky; top: 0; z-index: 10; background: #f2ede3; border-bottom: 1px solid #ccc5b8; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
      <div style="display: flex; align-items: center; gap: 2rem;">
        <a href="/admin" style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8076; text-decoration: none;">
          ← Posts
        </a>
        <span style="color: #ccc5b8;">|</span>
        <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1612;">
          New Post
        </span>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076; background: none; border: none; cursor: pointer; padding: 0;">
          Sign out
        </button>
      </form>
    </header>

    <main style="max-width: 1000px; margin: 0 auto; padding: 3rem 2rem 6rem;">
      <form id="post-form" style="display: flex; flex-direction: column; gap: 2rem;">

        <!-- Title + slug -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
          <div>
            <label class="field-label">Title</label>
            <input id="title" name="title" type="text" required class="field-input" />
          </div>
          <div>
            <label class="field-label">Slug</label>
            <input id="slug" name="slug" type="text" required class="field-input field-input--mono" />
          </div>
        </div>

        <!-- Description -->
        <div>
          <label class="field-label">Description</label>
          <textarea id="description" name="description" rows="2" class="field-input" style="resize: vertical;"></textarea>
        </div>

        <!-- Body -->
        <div>
          <label class="field-label">Body</label>
          <MarkdownEditor value="" />
        </div>

        <!-- Hero image -->
        <div>
          <label class="field-label">Hero Image</label>
          <div style="display: flex; gap: 0.75rem; align-items: stretch;">
            <input id="hero_image" name="hero_image" type="text" class="field-input" placeholder="URL or upload →" style="flex: 1;" />
            <label class="btn-upload" title="Upload image">
              Upload
              <input type="file" id="hero-upload-input" accept="image/*" style="display:none;" />
            </label>
          </div>
          <div id="hero-preview-wrap" style="display:none; margin-top: 0.75rem;">
            <img id="hero-preview" src="" alt="" style="max-height: 160px; max-width: 100%; object-fit: cover; border: 1px solid #ccc5b8;" />
          </div>
        </div>

        <!-- Meta row -->
        <div style="background: #ede8de; border: 1px solid #ccc5b8; padding: 1.5rem; display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.5rem; align-items: end;">
          <div>
            <label class="field-label">Tags</label>
            <input id="tags" name="tags" type="text" class="field-input" placeholder="Go, TypeScript" />
          </div>
          <div>
            <label class="field-label">Type</label>
            <select id="type" name="type" class="field-input">
              <option value="blog">Blog</option>
              <option value="projects">Projects</option>
            </select>
          </div>
          <div>
            <label class="field-label">Status</label>
            <select id="status" name="status" class="field-input">
              <option value="active">Active</option>
              <option value="wip">WIP</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div>
            <label class="field-label">Date</label>
            <input id="date" name="date" type="date" required class="field-input" />
          </div>
        </div>

        <!-- Published + submit -->
        <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 0.75rem; border-top: 1px solid #ccc5b8;">
          <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076;">
            <input id="published" name="published" type="checkbox" style="width: 15px; height: 15px; accent-color: #1a1612;" />
            Published
          </label>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <span id="save-status" style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.06em; color: #b5421a; opacity: 0; transition: opacity 0.3s;"></span>
            <button id="save-btn" type="submit" class="btn-save">Create post</button>
          </div>
        </div>

      </form>
    </main>

    <style>
      .field-label {
        display: block;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6a6460;
        margin-bottom: 0.5rem;
      }
      .field-input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.75rem 1rem;
        background: transparent;
        border: 1px solid #ccc5b8;
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 1rem;
        font-weight: 300;
        color: #1a1612;
        outline: none;
        appearance: none;
      }
      .field-input:focus { border-color: #8a8076; }
      .field-input--mono { font-family: 'Space Mono', monospace; font-size: 0.85rem; }
      .btn-upload {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #8a8076;
        background: #ede8de;
        border: 1px solid #ccc5b8;
        cursor: pointer;
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        white-space: nowrap;
        transition: color 0.15s;
      }
      .btn-upload:hover { color: #1a1612; }
      .btn-save {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #f2ede3;
        background: #1a1612;
        border: none;
        cursor: pointer;
        padding: 0.75rem 1.75rem;
        transition: background 0.2s;
      }
      .btn-save:disabled { opacity: 0.6; cursor: not-allowed; }
      .btn-save.is-error { background: #b5421a; }
    </style>

    <script>
      // Hero image upload
      const heroInput = document.getElementById("hero_image") as HTMLInputElement;
      const heroUpload = document.getElementById("hero-upload-input") as HTMLInputElement;
      const heroPreviewWrap = document.getElementById("hero-preview-wrap") as HTMLDivElement;
      const heroPreview = document.getElementById("hero-preview") as HTMLImageElement;

      heroUpload.addEventListener("change", async () => {
        const file = heroUpload.files?.[0];
        if (!file) return;
        const label = heroUpload.closest("label") as HTMLLabelElement;
        label.childNodes[0].textContent = "Uploading… ";
        try {
          const fd = new FormData();
          fd.append("file", file);
          const res = await fetch("/api/uploads", { method: "POST", body: fd });
          if (!res.ok) throw new Error();
          const { url } = await res.json() as { url: string };
          heroInput.value = url;
          heroPreview.src = url;
          heroPreviewWrap.style.display = "block";
        } catch {
          alert("Upload failed.");
        } finally {
          label.childNodes[0].textContent = "Upload ";
        }
      });

      heroInput.addEventListener("input", () => {
        const url = heroInput.value.trim();
        if (url) {
          heroPreview.src = url;
          heroPreviewWrap.style.display = "block";
        } else {
          heroPreviewWrap.style.display = "none";
        }
      });

      // Auto-generate slug from title
      const titleEl = document.getElementById("title") as HTMLInputElement;
      const slugEl = document.getElementById("slug") as HTMLInputElement;
      let slugEdited = false;

      slugEl.addEventListener("input", () => { slugEdited = true; });
      titleEl.addEventListener("input", () => {
        if (slugEdited) return;
        slugEl.value = titleEl.value
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-")
          .trim();
      });

      // Default date to today
      const dateEl = document.getElementById("date") as HTMLInputElement;
      dateEl.value = new Date().toISOString().slice(0, 10);

      // Submit
      const form = document.getElementById("post-form") as HTMLFormElement;
      const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
      const saveStatus = document.getElementById("save-status") as HTMLSpanElement;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        saveBtn.textContent = "Creating…";
        saveBtn.disabled = true;
        saveBtn.classList.remove("is-error");
        saveStatus.style.opacity = "0";

        const tagsRaw = (document.getElementById("tags") as HTMLInputElement).value;
        const tags = tagsRaw.split(",").map((t) => t.trim()).filter(Boolean);

        const body = {
          title:       (document.getElementById("title") as HTMLInputElement).value,
          slug:        (document.getElementById("slug") as HTMLInputElement).value,
          description: (document.getElementById("description") as HTMLTextAreaElement).value,
          body:        (document.getElementById("body") as HTMLTextAreaElement).value,
          tags:        JSON.stringify(tags),
          type:        (document.getElementById("type") as HTMLSelectElement).value,
          status:      (document.getElementById("status") as HTMLSelectElement).value,
          published:   (document.getElementById("published") as HTMLInputElement).checked,
          date:        (document.getElementById("date") as HTMLInputElement).value,
          hero_image:  (document.getElementById("hero_image") as HTMLInputElement).value,
        };

        const res = await fetch("/api/posts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          const post = await res.json() as { slug: string };
          saveBtn.textContent = "Created ✓";
          setTimeout(() => {
            window.location.href = `/admin/posts/${post.slug}`;
          }, 600);
        } else {
          const err = await res.json() as { error?: string };
          saveBtn.textContent = "Create post";
          saveBtn.classList.add("is-error");
          saveStatus.textContent = err.error ?? "Failed to create post.";
          saveStatus.style.opacity = "1";
          saveBtn.disabled = false;
          setTimeout(() => {
            saveBtn.classList.remove("is-error");
          }, 3000);
        }
      });
    </script>

  </body>
</html>
