---
import MarkdownEditor from "../../../components/MarkdownEditor.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Post — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background: #f2ede3; margin: 0; min-height: 100svh; font-family: 'DM Sans', system-ui, sans-serif;">

    <!-- Top bar -->
    <header style="position: sticky; top: 0; z-index: 10; background: #f2ede3; border-bottom: 1px solid #ccc5b8; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
      <div style="display: flex; align-items: center; gap: 2rem;">
        <a href="/admin" style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8076; text-decoration: none;">
          ← Posts
        </a>
        <span style="color: #ccc5b8;">|</span>
        <span style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1612;">
          New Post
        </span>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076; background: none; border: none; cursor: pointer; padding: 0;">
          Sign out
        </button>
      </form>
    </header>

    <main style="max-width: 860px; margin: 0 auto; padding: 3rem 2rem 6rem;">

      <p id="status" style="font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.06em; min-height: 1.2em; color: #8a8076; margin-bottom: 1.5rem;"></p>

      <form id="post-form" style="display: flex; flex-direction: column; gap: 1.75rem;">

        <!-- Title + slug -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
          <div>
            <label class="field-label">Title</label>
            <input id="title" name="title" type="text" required class="field-input" />
          </div>
          <div>
            <label class="field-label">Slug</label>
            <input id="slug" name="slug" type="text" required class="field-input" style="font-family: 'Space Mono', monospace; font-size: 0.8rem;" />
          </div>
        </div>

        <!-- Description -->
        <div>
          <label class="field-label">Description</label>
          <textarea id="description" name="description" rows="2" class="field-input" style="resize: vertical;"></textarea>
        </div>

        <!-- Body -->
        <div>
          <label class="field-label">Body (Markdown)</label>
          <MarkdownEditor value="" />
        </div>

        <!-- Meta row -->
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.25rem; align-items: end;">
          <div>
            <label class="field-label">Tags (comma separated)</label>
            <input id="tags" name="tags" type="text" class="field-input" placeholder="Go, TypeScript" />
          </div>
          <div>
            <label class="field-label">Type</label>
            <select id="type" name="type" class="field-input">
              <option value="blog">Blog</option>
              <option value="projects">Projects</option>
            </select>
          </div>
          <div>
            <label class="field-label">Status</label>
            <select id="status" name="status" class="field-input">
              <option value="active">Active</option>
              <option value="wip">WIP</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div>
            <label class="field-label">Date</label>
            <input id="date" name="date" type="date" required class="field-input" />
          </div>
        </div>

        <!-- Published + submit -->
        <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 0.5rem; border-top: 1px solid #ccc5b8;">
          <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8076;">
            <input id="published" name="published" type="checkbox" style="width: 14px; height: 14px; accent-color: #1a1612;" />
            Published
          </label>
          <button
            type="submit"
            style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #f2ede3; background: #1a1612; border: none; cursor: pointer; padding: 0.7rem 1.5rem;"
          >
            Create post
          </button>
        </div>

      </form>
    </main>

    <style>
      .field-label {
        display: block;
        font-family: 'Space Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #8a8076;
        margin-bottom: 0.4rem;
      }
      .field-input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.65rem 0.85rem;
        background: transparent;
        border: 1px solid #ccc5b8;
        font-family: 'DM Sans', system-ui, sans-serif;
        font-size: 0.9rem;
        font-weight: 300;
        color: #1a1612;
        outline: none;
        appearance: none;
      }
      .field-input:focus { border-color: #8a8076; }
    </style>

    <script>
      // Auto-generate slug from title
      const titleEl = document.getElementById("title") as HTMLInputElement;
      const slugEl = document.getElementById("slug") as HTMLInputElement;
      let slugEdited = false;

      slugEl.addEventListener("input", () => { slugEdited = true; });
      titleEl.addEventListener("input", () => {
        if (slugEdited) return;
        slugEl.value = titleEl.value
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-")
          .trim();
      });

      // Default date to today
      const dateEl = document.getElementById("date") as HTMLInputElement;
      dateEl.value = new Date().toISOString().slice(0, 10);

      // Submit
      const form = document.getElementById("post-form") as HTMLFormElement;
      const status = document.getElementById("status")!;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.textContent = "Saving…";
        status.style.color = "#8a8076";

        const tagsRaw = (document.getElementById("tags") as HTMLInputElement).value;
        const tags = tagsRaw.split(",").map((t) => t.trim()).filter(Boolean);

        const body = {
          title:       (document.getElementById("title") as HTMLInputElement).value,
          slug:        (document.getElementById("slug") as HTMLInputElement).value,
          description: (document.getElementById("description") as HTMLTextAreaElement).value,
          body:        (document.getElementById("body") as HTMLTextAreaElement).value,
          tags:        JSON.stringify(tags),
          type:        (document.getElementById("type") as HTMLSelectElement).value,
          status:      (document.getElementById("status") as HTMLSelectElement).value,
          published:   (document.getElementById("published") as HTMLInputElement).checked,
          date:        (document.getElementById("date") as HTMLInputElement).value,
        };

        const res = await fetch("/api/posts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          const post = await res.json() as { slug: string };
          status.textContent = "Created.";
          status.style.color = "#6a8a6a";
          setTimeout(() => {
            window.location.href = `/admin/posts/${post.slug}`;
          }, 600);
        } else {
          const err = await res.json() as { error?: string };
          status.textContent = err.error ?? "Failed to create post.";
          status.style.color = "#b5421a";
        }
      });
    </script>

  </body>
</html>
