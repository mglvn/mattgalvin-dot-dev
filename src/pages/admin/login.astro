---
export const prerender = false;
const error = Astro.url.searchParams.get("error") === "1";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Matt Galvin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="background: #f2ede3; margin: 0; min-height: 100svh; display: flex; align-items: center; justify-content: center;">

    <div style="width: 100%; max-width: 380px; padding: 2.5rem;">
      <div style="margin-bottom: 2.5rem;">
        <a href="/" style="font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8076; text-decoration: none;">
          ← mattgalvin.dev
        </a>
      </div>

      <h1 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2.5rem; font-weight: 400; letter-spacing: -0.01em; color: #1a1612; margin: 0 0 0.5rem;">
        Admin
      </h1>
      <p style="font-size: 0.875rem; color: #8a8076; font-weight: 300; margin: 0 0 2.5rem;">
        Enter your password to continue.
      </p>

      {error && (
        <p style="font-family: 'Space Mono', monospace; font-size: 0.7rem; color: #b5421a; letter-spacing: 0.04em; margin-bottom: 1.5rem;">
          Incorrect password.
        </p>
      )}

      <form method="POST" action="/api/auth/login" style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label style="display: block; font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8076; margin-bottom: 0.5rem;">
            Password
          </label>
          <input
            type="password"
            name="password"
            required
            autofocus
            style="width: 100%; box-sizing: border-box; padding: 0.75rem 1rem; background: transparent; border: 1px solid #ccc5b8; font-family: 'Space Mono', monospace; font-size: 0.8rem; color: #1a1612; outline: none;"
          />
        </div>

        <button
          type="submit"
          style="padding: 0.75rem 1.5rem; background: #1a1612; color: #f2ede3; font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; border: none; cursor: pointer;"
        >
          Sign in
        </button>
      </form>
    </div>

  </body>
</html>
